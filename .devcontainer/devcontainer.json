{
  "name": "Corbitraj",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "forwardPorts": [8001],
  "portsAttributes": {
    "8001": {
      "label": "Corbitraj Dashboard",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "python -m pip install --upgrade pip && pip install -r requirements.txt && cp -n .env.example .env.local || true",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
